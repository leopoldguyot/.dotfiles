#!/usr/bin/env bash
set -e

usage() {
    cat <<'EOF'
Usage: update-pkgs

Install/update pacman and AUR packages listed in arch_install/*.txt.
EOF
}

if [[ $# -gt 0 ]]; then
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
fi

ARCH_DIR="$HOME/.local/bin/arch_install"
source $ARCH_DIR/lib/helpers.sh

PACMAN_SCRIPT="$ARCH_DIR/modules/01-pacman-pkgs.sh"
AUR_SCRIPT="$ARCH_DIR/modules/02-aur-pkgs.sh"
PACMAN_TXT="$ARCH_DIR/pacman-pkgs-list.txt"
AUR_TXT="$ARCH_DIR/aur-pkgs-list.txt"

echo "[+] Starting updating pacman pkgs"
echo "[+] Using $PACMAN_TXT"

source $PACMAN_SCRIPT

echo "[+] Starting updating aur pkgs"
echo "[+] Using $AUR_TXT"

source $AUR_SCRIPT

echo "[+] Packages update done!"
