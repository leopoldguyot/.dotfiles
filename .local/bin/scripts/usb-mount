#!/usr/bin/env bash

set -euo pipefail

PROGRAM_NAME="$(basename "$0")"
LSBLK_FIELDS="NAME,TYPE,RM,SIZE,FSTYPE,LABEL,MOUNTPOINT,TRAN"

CANDIDATES=()
SELECTED_LINE=""
MOUNTED_DEVICE=""
MOUNTED_POINT=""

usage() {
    cat <<EOF
Usage: $PROGRAM_NAME [--list] [--device /dev/sdXN]

List and mount removable USB partitions.

Options:
  --list             List mountable removable USB partitions and exit
  --device <path>    Mount the given block device directly
  -h, --help         Show this help message
EOF
}

require_command() {
    local cmd="$1"
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Missing required command: $cmd" >&2
        exit 1
    fi
}

extract_field() {
    local line="$1"
    local key="$2"
    local value="${line#*${key}=\"}"

    if [[ "$value" == "$line" ]]; then
        echo ""
        return
    fi

    echo "${value%%\"*}"
}

collect_candidates() {
    local line type rm transport
    CANDIDATES=()

    while IFS= read -r line; do
        type="$(extract_field "$line" "TYPE")"
        rm="$(extract_field "$line" "RM")"
        transport="$(extract_field "$line" "TRAN")"

        if [[ "$type" == "part" && ( "$rm" == "1" || "$transport" == "usb" ) ]]; then
            CANDIDATES+=("$line")
        fi
    done < <(lsblk -p -P -o "$LSBLK_FIELDS")
}

print_candidates() {
    local i line name size fs label mountpoint state

    if [[ ${#CANDIDATES[@]} -eq 0 ]]; then
        echo "No removable USB partitions detected."
        return 1
    fi

    printf "%-3s %-12s %-8s %-8s %-18s %-10s %s\n" \
        "ID" "DEVICE" "SIZE" "FS" "LABEL" "STATE" "MOUNTPOINT"

    for i in "${!CANDIDATES[@]}"; do
        line="${CANDIDATES[$i]}"
        name="$(extract_field "$line" "NAME")"
        size="$(extract_field "$line" "SIZE")"
        fs="$(extract_field "$line" "FSTYPE")"
        label="$(extract_field "$line" "LABEL")"
        mountpoint="$(extract_field "$line" "MOUNTPOINT")"

        [[ -z "$fs" ]] && fs="-"
        [[ -z "$label" ]] && label="-"

        if [[ -n "$mountpoint" ]]; then
            state="mounted"
        else
            state="unmounted"
            mountpoint="-"
        fi

        printf "%-3s %-12s %-8s %-8s %-18s %-10s %s\n" \
            "$((i + 1))" "$name" "$size" "$fs" "$label" "$state" "$mountpoint"
    done
}

select_candidate() {
    local choice

    while true; do
        read -rp "Select partition number (r=refresh, q=quit): " choice

        case "$choice" in
            [Qq]) return 1 ;;
            [Rr])
                collect_candidates
                print_candidates || return 1
                ;;
            *)
                if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#CANDIDATES[@]} )); then
                    SELECTED_LINE="${CANDIDATES[$((choice - 1))]}"
                    return 0
                fi
                echo "Invalid selection."
                ;;
        esac
    done
}

mount_device() {
    local device="$1"
    local output mountpoint

    mountpoint="$(findmnt -rn -S "$device" -o TARGET || true)"
    if [[ -n "$mountpoint" ]]; then
        echo "$device is already mounted at $mountpoint"
        MOUNTED_DEVICE="$device"
        MOUNTED_POINT="$mountpoint"
        return 0
    fi

    output="$(udisksctl mount -b "$device")"
    echo "$output"

    mountpoint="$(printf '%s\n' "$output" | sed -n 's/.* at \(.*\)\.$/\1/p' | head -n1)"
    if [[ -z "$mountpoint" ]]; then
        mountpoint="$(findmnt -rn -S "$device" -o TARGET || true)"
    fi

    if [[ -z "$mountpoint" ]]; then
        echo "Could not determine mountpoint for $device." >&2
        return 1
    fi

    MOUNTED_DEVICE="$device"
    MOUNTED_POINT="$mountpoint"
    echo "Mounted $MOUNTED_DEVICE at $MOUNTED_POINT"
}

main() {
    local list_only=0 selected_device="" arg

    while [[ $# -gt 0 ]]; do
        arg="$1"
        case "$arg" in
            --list) list_only=1 ;;
            --device)
                shift
                if [[ $# -eq 0 ]]; then
                    echo "Missing value for --device" >&2
                    usage >&2
                    exit 1
                fi
                selected_device="$1"
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown argument: $arg" >&2
                usage >&2
                exit 1
                ;;
        esac
        shift
    done

    for cmd in lsblk findmnt udisksctl; do
        require_command "$cmd"
    done

    if [[ -n "$selected_device" ]]; then
        if [[ ! -b "$selected_device" ]]; then
            echo "Block device not found: $selected_device" >&2
            exit 1
        fi
        mount_device "$selected_device"
        exit 0
    fi

    collect_candidates
    if [[ "$list_only" -eq 1 ]]; then
        print_candidates
        exit $?
    fi

    print_candidates || exit 1

    if ! select_candidate; then
        exit 0
    fi

    selected_device="$(extract_field "$SELECTED_LINE" "NAME")"
    mount_device "$selected_device"
}

main "$@"
