#!/usr/bin/env bash
set -euo pipefail

mode_file="/tmp/waybar-resources.mode"
state_file="/tmp/waybar-resources-cpu.state"

usage() {
    cat <<EOF
Usage: $(basename "$0") [toggle|compact|detailed]

Without arguments, prints current CPU/RAM/temperature summary for Waybar.
EOF
}

case "${1:-}" in
    -h|--help)
        usage
        exit 0
        ;;
    toggle)
        current_mode="compact"
        if [[ -f "$mode_file" ]]; then
            read -r current_mode < "$mode_file" || current_mode="compact"
        fi
        if [[ "$current_mode" == "detailed" ]]; then
            printf "compact\n" > "$mode_file"
        else
            printf "detailed\n" > "$mode_file"
        fi
        exit 0
        ;;
    compact|detailed)
        printf "%s\n" "$1" > "$mode_file"
        exit 0
        ;;
esac

mode="compact"
if [[ -f "$mode_file" ]]; then
    read -r mode < "$mode_file" || mode="compact"
fi
if [[ "$mode" != "compact" && "$mode" != "detailed" ]]; then
    mode="compact"
fi

read -r mem_used_gb mem_total_gb mem_used_pct < <(
    awk '
        /MemTotal/ {t=$2}
        /MemAvailable/ {a=$2}
        END {
            u=t-a
            printf("%.1f %.1f %d\n", u/1024/1024, t/1024/1024, (100*u)/t)
        }
    ' /proc/meminfo
)

read -r cur_idle cur_total < <(awk '/^cpu /{idle=$5; total=0; for(i=2;i<=NF;i++) total+=$i; print idle, total; exit}' /proc/stat)

if [[ -f "$state_file" ]]; then
    read -r prev_idle prev_total < "$state_file" || true
else
    prev_idle="$cur_idle"
    prev_total="$cur_total"
fi

echo "$cur_idle $cur_total" > "$state_file"

delta_total=$((cur_total - prev_total))
delta_idle=$((cur_idle - prev_idle))
if (( delta_total > 0 )); then
    cpu_pct=$(( (100 * (delta_total - delta_idle)) / delta_total ))
else
    cpu_pct=0
fi

read_temp_file() {
    local file raw
    file="$1"
    [[ -r "$file" ]] || return 1
    raw="$(<"$file")"
    [[ "$raw" =~ ^[0-9]+$ ]] || return 1
    (( raw > 0 )) || return 1

    if (( raw >= 1000 )); then
        printf "%d" "$((raw / 1000))"
    else
        printf "%d" "$raw"
    fi
}

temp_from_thermal_type() {
    local wanted zone type
    wanted="$1"
    for zone in /sys/class/thermal/thermal_zone*; do
        [[ -d "$zone" ]] || continue
        [[ -r "$zone/type" ]] || continue
        type="$(<"$zone/type")"
        if [[ "$type" == "$wanted" ]]; then
            read_temp_file "$zone/temp" && return 0
        fi
    done
    return 1
}

temp_from_hwmon_name_label() {
    local wanted_name wanted_label hwmon label_file input_file
    wanted_name="$1"
    wanted_label="$2"

    for hwmon in /sys/class/hwmon/hwmon*; do
        [[ -d "$hwmon" ]] || continue
        [[ -r "$hwmon/name" ]] || continue
        [[ "$(<"$hwmon/name")" == "$wanted_name" ]] || continue

        for label_file in "$hwmon"/temp*_label; do
            [[ -f "$label_file" ]] || continue
            [[ "$(<"$label_file")" == "$wanted_label" ]] || continue
            input_file="${label_file%_label}_input"
            read_temp_file "$input_file" && return 0
        done
    done
    return 1
}

temp_from_hwmon_label() {
    local wanted label_file input_file
    wanted="$1"
    for label_file in /sys/class/hwmon/hwmon*/temp*_label; do
        [[ -f "$label_file" ]] || continue
        [[ "$(<"$label_file")" == "$wanted" ]] || continue
        input_file="${label_file%_label}_input"
        read_temp_file "$input_file" && return 0
    done
    return 1
}

temp_from_hottest_sensor() {
    local sensor temp best=-1
    for sensor in /sys/class/thermal/thermal_zone*/temp /sys/class/hwmon/hwmon*/temp*_input; do
        [[ -f "$sensor" ]] || continue
        temp="$(read_temp_file "$sensor" || true)"
        [[ -n "$temp" ]] || continue
        (( temp > best )) && best="$temp"
    done
    (( best >= 0 )) || return 1
    printf "%d" "$best"
}

temp_c="$(
    temp_from_thermal_type "x86_pkg_temp" \
    || temp_from_thermal_type "TCPU" \
    || temp_from_hwmon_name_label "coretemp" "Package id 0" \
    || temp_from_hwmon_label "CPU" \
    || temp_from_hwmon_label "Tctl" \
    || temp_from_hottest_sensor \
    || printf "?"
)"

if [[ "$mode" == "detailed" ]]; then
    echo " ${cpu_pct}%   ${mem_used_gb}G/${mem_total_gb}G (${mem_used_pct}%)   ${temp_c}°"
else
    echo " ${cpu_pct}%   ${mem_used_gb}G   ${temp_c}°"
fi
