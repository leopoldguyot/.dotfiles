#!/usr/bin/env bash
set -euo pipefail

max_len=22

track="$(playerctl metadata --format '{{ artist }} - {{ title }}' 2>/dev/null || true)"
status="$(playerctl status 2>/dev/null || true)"

if [[ -z "$track" || "$track" == *"No players found"* ]]; then
    echo "No media"
    exit 0
fi

if [[ "$status" != "Playing" ]]; then
    echo "$track"
    exit 0
fi

python3 - "$track" "$max_len" <<'PY'
import sys

text = sys.argv[1]
max_len = int(sys.argv[2])

if len(text) <= max_len:
    print(text)
    raise SystemExit(0)

padding = "   "
scroll = text + padding + text
step = int(__import__("time").time() * 2) % (len(text) + len(padding))
print(scroll[step:step + max_len])
PY
